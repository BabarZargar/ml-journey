    "import matplotlib.pyplot as plt\n",
    "import numpy as np\n",
    "\n",
    "x = np.array([1, 2, 3, 4, 5])\n",
    "y = np.array([5, 10, 15, 20, 25])\n",
    "\n",
    "plt.grid(axis = \"y\",\n",
    "         linewidth = 2,\n",
    "         color = \"lightblue\",\n",
    "         linestyle = \"dashed\")\n",
    "\n",
    "plt.plot(x, y)\n",
    "plt.show()\n",
    "\n"
   ]
  }
